{
  "info": {
    "name": "Veetu Vadagai API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "token", "value": "" },
    { "key": "propertyId", "value": "" },
    { "key": "tenantId", "value": "" },
    { "key": "tenantUserId", "value": "" },
    { "key": "paymentId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as owner",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\":\"owner@veetu.test\",\"password\":\"Password@123\"}" }
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": { "mode": "raw", "raw": "{\"refreshToken\":\"paste-refresh-token\"}" }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Owner dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/owner"
          }
        },
        {
          "name": "Tenant dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/tenant"
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "List owner properties",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/properties/all"
          }
        },
        {
          "name": "Create property",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/properties",
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"Anna Nagar Flat\",\"type\":\"APARTMENT\",\"addressLine1\":\"1 Main Road\",\"addressLine2\":\"Near Metro\",\"city\":\"Chennai\",\"state\":\"Tamil Nadu\",\"postalCode\":\"600040\",\"rentAmount\":30000,\"advanceAmount\":120000,\"dueDay\":5,\"occupied\":false}"
            }
          }
        },
        {
          "name": "Delete property",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/properties/{{propertyId}}"
          }
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "List tenants",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/tenants"
          }
        },
        {
          "name": "Add tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/tenants",
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"tenant2@veetu.test\",\"fullName\":\"Second Tenant\",\"mobile\":\"9999999999\",\"propertyId\":\"{{propertyId}}\",\"emergencyContact\":\"9888888888\",\"kycDocumentUrl\":\"https://example.com/kyc.pdf\",\"moveInDate\":\"2026-06-01\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "List payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Create payment request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\"propertyId\":\"{{propertyId}}\",\"payerId\":\"{{tenantUserId}}\",\"type\":\"RENT\",\"amount\":30000,\"dueDate\":\"2026-06-05\"}"
            }
          }
        },
        {
          "name": "Mark payment successful",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/payments/{{paymentId}}/success"
          }
        },
        {
          "name": "Send reminder",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/payments/{{paymentId}}/reminders"
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "List invoices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/invoices"
          }
        },
        {
          "name": "Download receipt",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/invoices/{{paymentId}}/pdf"
          }
        },
        {
          "name": "List agreements",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/agreements"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/notifications"
          }
        },
        {
          "name": "Unread count",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/notifications/unread-count"
          }
        }
      ]
    }
  ]
}
